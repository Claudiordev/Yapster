# Production build + runtime config baked into the Docker image. Next.js loads
# this both at `next build` and when the standalone server starts. A local
# `.env.local` (gitignored, dockerignored) still overrides it for a local
# production build.

# Backend gateway — the router service name on the docker-compose network.
API_BASE_URL=http://router:8080

# This compose setup serves over plain HTTP on the LAN, so secure cookies are
# off (a Secure cookie is dropped by the browser over http://). Behind real
# HTTPS, set this to true.
COOKIE_SECURE=false

# RS256 public key for verifying session JWTs (a public key — safe to commit).
JWT_PUBLIC_KEY=`-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA2iuA//Z5EypmPB0ddHuB
0dHwgnvM0XJ8R+h1hffyPEKdq7t+Ik9Wm2Qgh58AvFslpSU0laueXA/ftpfrXjBf
T+YgMs94IiBpvPeuhrJyEDbH2D/dspUDOjUfkvhvZobacQukWzdKrf7dAAH+BmJ2
QL/8zSsMgBpNWKbuW1h3pWQpPg0y30qgF7pAq3wrjoRlZwVF6nTm8gkDxAkEN5W6
ChMqVbJcUxxcB13k8rdCd/Ok9xWM2jP+DtRWNzsLfM9/jGBIOuAGe2Rce2jNPMWf
wPA/hP6qk8UXKYnzuSmJwivQnmHpnHYNJcZB2DhnO03kFsBeAeMx0WsjeeTywj6d
